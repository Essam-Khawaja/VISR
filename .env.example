# Optional — without this key, Pathwise uses deterministic fallbacks (works offline).
GROQ_API_KEY=

# Optional model override (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional Supabase persistence. Demo and deterministic fallbacks do not require these.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Demo plan id for "View demo strategy" CTA (default: demo-cs-student-001)
# NEXT_PUBLIC_DEMO_PLAN_ID=demo-cs-student-001
